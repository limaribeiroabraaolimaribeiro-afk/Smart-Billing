# ==============================
# Smart Billing - Variaveis de Ambiente
# ==============================

# Porta do servidor
PORT=3000

# URL base publica da aplicacao (usada para montar links de pagamento, recibo e back_urls/webhook do Mercado Pago)
# Em desenvolvimento local pode usar http://localhost:3000
# Em producao, use a URL publica com HTTPS (ex: https://cobranca.suaempresa.com)
BASE_URL=http://localhost:3000

# ------------------------------
# Supabase
# ------------------------------
# URL do projeto Supabase (Settings > API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Service Role Key (Settings > API) - NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# ------------------------------
# Autenticacao do Admin (login simples)
# ------------------------------
ADMIN_EMAIL=admin@smartbilling.com
# Hash bcrypt da senha do admin. Gere com: node scripts/gerar-hash-senha.js "suasenha"
ADMIN_PASSWORD_HASH=SUBSTITUA_PELO_HASH_GERADO
# Segredo usado para assinar o token JWT do login admin
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=8h

# ------------------------------
# Mercado Pago (Checkout Pro)
# ------------------------------
# Access Token PRIVADO da sua conta/aplicacao Mercado Pago (NUNCA exponha no frontend)
MERCADOPAGO_ACCESS_TOKEN=SEU_ACCESS_TOKEN_MERCADO_PAGO

# ------------------------------
# WhatsApp (estrutura preparada para envio automatico)
# ------------------------------
# Preencha quando integrar um provedor real (ex: WhatsApp Cloud API, Twilio, Z-API etc.)
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_TOKEN=
# Numero remetente usado pelo provedor (formato internacional, ex: 5511999999999)
WHATSAPP_SENDER_NUMBER=

# Ativa o agendador automatico de lembretes de cobranca (true/false)
ENABLE_BILLING_SCHEDULER=true
# Horario diario (cron) em que o agendador roda - padrao 09:00 todos os dias
BILLING_SCHEDULER_CRON=0 9 * * *
