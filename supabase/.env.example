# ==============================================================
# Smart Billing - Secrets das Supabase Edge Functions
# ==============================================================
# Este arquivo e apenas uma referencia. Em producao, os valores sao
# configurados com `supabase secrets set` (ou pelo dashboard em
# Project Settings > Edge Functions > Secrets), nunca commitados.
#
# Para rodar as functions localmente com a Supabase CLI, copie este
# arquivo para "supabase/.env" (que ja esta no .gitignore) e rode:
#   supabase functions serve --env-file supabase/.env
# ==============================================================

# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY sao injetados automaticamente
# pelo runtime das Edge Functions em producao. So precisam ser definidos
# aqui para rodar localmente com `supabase functions serve`.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# URL publica onde o FRONTEND estatico esta hospedado (Supabase Storage,
# Edge Function "app", Vercel, Netlify etc.). Usada para montar o
# payment_link das cobrancas e os back_urls do Mercado Pago.
APP_URL=https://SEU-FRONTEND.exemplo.com

# ------------------------------
# Login do admin (login simples)
# ------------------------------
ADMIN_EMAIL=admin@smartbilling.com
# Hash bcrypt da senha do admin. Gere com: node scripts/gerar-hash-senha.js "suasenha"
ADMIN_PASSWORD_HASH=SUBSTITUA_PELO_HASH_GERADO
# Segredo usado para assinar o JWT proprio do admin (emitido por admin-login)
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=8h

# ------------------------------
# Mercado Pago (Checkout Pro)
# ------------------------------
MERCADO_PAGO_ACCESS_TOKEN=SEU_ACCESS_TOKEN_MERCADO_PAGO

# ------------------------------
# WhatsApp (estrutura preparada para envio automatico)
# ------------------------------
# Preencha quando integrar um provedor real (ex: WhatsApp Cloud API, Twilio, Z-API etc.)
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_TOKEN=

# ------------------------------
# Supabase Cron -> whatsapp-cron
# ------------------------------
# Segredo compartilhado entre o agendamento (database/cron.sql) e a function
# whatsapp-cron, enviado no header "x-cron-secret" para autorizar a chamada.
CRON_SECRET=troque-por-outra-string-longa-e-aleatoria
